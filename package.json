{
  "name": "atlas-ui",
  "version": "0.0.0",
  "type": "module",
  "description": "URA-compliant React component library.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "DESIGN.md",
    "docs"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/verification-runner.mjs build",
    "build:raw": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "node scripts/verification-runner.mjs build-storybook",
    "build-storybook:raw": "storybook build",
    "test": "node scripts/verification-runner.mjs test",
    "test:raw": "vitest run --reporter dot",
    "test:watch": "vitest",
    "guardrails": "node scripts/verification-runner.mjs guardrails",
    "guardrails:raw": "node scripts/ura-guardrails.mjs",
    "paperclip:doctor": "npx paperclipai doctor",
    "paperclip:run": "npx paperclipai run",
    "paperclip:project": "npx paperclipai project list --company-id 3e75431a-4c18-498b-919c-81d067e4fbb9",
    "check": "node scripts/verification-runner.mjs check"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "storybook": "^10.4.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
